# Public browser-safe Supabase values. Leave blank until a project is configured.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Public base URL used only to build safe email-confirmation callbacks.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Server-only. Never prefix this value with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Business date/time presentation zone. PostgreSQL timestamps remain timestamptz.
TZ=Asia/Riyadh
